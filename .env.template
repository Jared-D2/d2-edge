# --- Site identity --------------------------------------------------------
# TZ: timezone for the Pi (e.g. Australia/Sydney, Australia/Melbourne)
TZ=Australia/Sydney

# EDGE_HOSTNAME: unique hostname for this Pi (e.g. d2-customer-site01)
EDGE_HOSTNAME=REPLACE_ME

# EDGE_SITE_ID: short site identifier, no spaces (e.g. denisonst, northsyd)
EDGE_SITE_ID=REPLACE_ME

# TENANT_ID: customer ID in your system (e.g. d2001)
TENANT_ID=REPLACE_ME

# TENANT_NAME: customer name, no spaces (e.g. D2_Technology)
TENANT_NAME=REPLACE_ME

# ENVIRONMENT: production or staging
ENVIRONMENT=production

# --- Tailscale ------------------------------------------------------------
# Generate at https://login.tailscale.com/admin/settings/keys
TS_AUTHKEY=REPLACE_ME

# --- Upstream destinations (do not change unless infrastructure changes) --
GRAYLOG_HOST=10.255.255.20
ZABBIX_SERVER_HOST=10.255.255.4
ZABBIX_SERVER_PORT=10051
RADIUS_HOME_SERVER=10.255.255.13

# --- RADIUS secrets -------------------------------------------------------
# RADIUS_SHARED_SECRET: secret between this Pi and central FreeRADIUS
# (10.255.255.13). Currently ONE fleet-wide value — all Pis share it
# because their traffic reaches central via the Tailscale subnet router
# (10.255.255.44) and appears from one source IP. See reference_radius.
# If you generate a per-Pi secret, you must also add a matching client
# block on central's clients.conf or auth will fail.
RADIUS_SHARED_SECRET=REPLACE_ME

# LOCAL_CLIENT_SECRET: secret customer devices (APs/switches) use to talk
# to this Pi's RADIUS proxy. Generate randomly per Pi.
LOCAL_CLIENT_SECRET=REPLACE_ME

# LOCAL_CLIENT_SUBNET: customer LAN CIDR(s). Accepts either a single
# CIDR (e.g. 10.0.0.0/8) OR a comma-separated list (no spaces)
# (e.g. 10.0.0.0/8,192.168.1.0/24,172.16.0.0/12).
# Space-separated also works but requires quotes since .env is sourced
# by bash: LOCAL_CLIENT_SUBNET="10.0.0.0/8 192.168.1.0/24".
# render-configs.sh generates one FreeRADIUS client block per entry.
LOCAL_CLIENT_SUBNET=REPLACE_ME

# --- Auvik ----------------------------------------------------------------
# AUVIK_USERNAME + AUVIK_API_KEY are fleet-wide (single MSP account, same
# value on every Pi — used for initial deployment only).
AUVIK_USERNAME=jared.cooper@d2tech.com.au
AUVIK_API_KEY=REPLACE_ME
# AUVIK_DOMAIN_PREFIX: per-customer Auvik subdomain. Set to this customer's
# TENANT_ID (e.g. nib001 for NIB, d2001 for D2 Technology HQ). Each customer
# has their own Auvik tenant under the D2 MSP account.
AUVIK_DOMAIN_PREFIX=REPLACE_ME

# --- D2 Network Test Agent ------------------------------------------------
# AGENT_TOKEN: fleet-wide shared secret for agent->controller auth. Same
# value on every Pi. Agents identify themselves by AGENT_ID (=EDGE_HOSTNAME),
# the token only authenticates that they are part of the D2 fleet.
# Fetch from /opt/netbox/onboarding/.env (EDGE_AGENT_TOKEN).
AGENT_TOKEN=REPLACE_ME
# NETBOX_SITE_SLUG: the NetBox site slug for this tenant/site (e.g. newcastle-west)
NETBOX_SITE_SLUG=REPLACE_ME
CONTROLLER_URL=wss://10.255.255.36:9000/ws/agent

# --- Service deployment toggles ------------------------------------------
# compose profiles gate syslog-proxy / zabbix-proxy / zabbix-agent2 /
# freeradius-proxy / auvik / d2-agent. All default to 'enabled' but the
# profile tag itself must match via COMPOSE_PROFILES below, or nothing
# in a profile group will start on `docker compose up -d`.
COMPOSE_PROFILES=enabled

# --- Docker group GID (set by bootstrap.sh) ------------------------------
# Do not edit manually — bootstrap resolves this from `getent group docker`.
# zabbix-agent2 uses it via group_add to access /var/run/docker.sock for
# the container-metrics plugin.
DOCKER_GID=
